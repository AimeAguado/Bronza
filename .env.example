# Opcional: URL absoluta del backend en producción (si el front y la API están en distintos dominios)
# VITE_API_URL=https://api.tudominio.com

# URL del checkout de Mercado Pago (init_point de una Preferencia) o tu "link de pago".
# Ejemplo: https://www.mercadopago.com.ar/checkout/v1/redirect?pref_id=...
# Para que el monto coincida siempre con el carrito, lo ideal es crear la preferencia
# en tu backend con los ítems y el total, y pegar aquí la URL que devuelve (init_point).
# Sin esto, en checkout verás un aviso para configurarla.
VITE_MERCADOPAGO_INIT_POINT=
