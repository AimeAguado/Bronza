PORT=4000
# Generá uno largo y aleatorio: openssl rand -hex 32
JWT_SECRET=cambiar_por_un_secreto_largo_y_unico

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<app>

# Cloudinary (para upload de imágenes)
# Conseguilo en: cloudinary.com → Settings → API Keys
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Opcional: token de producción o test de Mercado Pago (nunca lo subas al repo)
# https://www.mercadopago.com.ar/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=

# URLs de retorno después del pago (Checkout Pro)
MP_SUCCESS_URL=http://localhost:5173/?payment=success
MP_FAILURE_URL=http://localhost:5173/?payment=failure
MP_PENDING_URL=http://localhost:5173/?payment=pending
